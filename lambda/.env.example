# AWS Region
AWS_REGION=us-east-1

# Secrets Manager — secret name storing { apiKey, cardBackendUrl }
CARD_BACKEND_SECRET_NAME=fintech-ivr/card-backend

# DynamoDB — used for call state tracking AND handoff context (screen pop)
DYNAMODB_TABLE=ivr-call-state

# API Gateway endpoint (set after deploying Lambda)
LAMBDA_URL=https://YOUR_API_GATEWAY_ID.execute-api.us-east-1.amazonaws.com/prod/ivr

# Amazon Connect — the existing Intuit IBCC inbound phone number.
# Twilio dials this number for warm handoffs, re-entering Connect's existing flow.
CONNECT_INBOUND_NUMBER=+15128675309

# Amazon Connect instance ID — used by the Connect Contact Flow Lambda for screen pop
CONNECT_INSTANCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Twilio Conversation Intelligence service SID
VOICE_INTELLIGENCE_SERVICE_SID=GA00000000000000000000000000000000
